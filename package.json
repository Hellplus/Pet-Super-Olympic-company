{
  "name": "ipoc-admin",
  "version": "1.0.0",
  "private": true,
  "description": "国际宠物奥林匹克超级赛组委会内部数字化管控系统",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:backend": "pnpm --filter @ipoc/backend run start:dev",
    "dev:frontend": "pnpm --filter @ipoc/frontend run dev",
    "build": "pnpm -r run build",
    "build:backend": "pnpm --filter @ipoc/backend run build",
    "build:frontend": "pnpm --filter @ipoc/frontend run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  }
}
